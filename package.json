{
  "name": "chat-bot",
  "version": "1.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/EugeneDraitsev/telegram-bot-app"
  },
  "author": "Eugene Draitsev <ddrrai@gmail.com>",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "sls offline start --stage local",
    "build": "bun run prepare:sharp-layer && sls package",
    "tsc": "tsc --noEmit",
    "test": "bun test",
    "audit": "bun audit",
    "biome": "biome check ./src",
    "biome:fix": "biome check ./src --fix --unsafe",
    "logs": "sls logs -f telegram-bot -t",
    "diagram": "bunx @mermaid-js/mermaid-cli@11 -i .github/diagram/architecture.mmd -o .github/architecture-light.svg -c .github/diagram/light.json -b transparent --iconPacks @iconify-json/logos @iconify-json/mdi @iconify-json/simple-icons && bunx @mermaid-js/mermaid-cli@11 -i .github/diagram/architecture.mmd -o .github/architecture-dark.svg -c .github/diagram/dark.json -b transparent --iconPacks @iconify-json/logos @iconify-json/mdi @iconify-json/simple-icons",
    "deploy": "bun run prepare:sharp-layer && sls deploy",
    "prepare:sharp-layer": "bun tools/prepare-sharp-layer.mts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/aws-lambda": "^8.10.162",
    "@types/jest": "^30.0.0",
    "esbuild": "0.28.1",
    "serverless": "^4.38.1",
    "serverless-esbuild": "^1.57.2",
    "serverless-offline": "^14.7.4",
    "typescript": "^7.0.2"
  },
  "workspaces": [
    "src/*"
  ],
  "overrides": {
    "uuid": "11.1.1"
  }
}
