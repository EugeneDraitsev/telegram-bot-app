{
  "name": "chat-bot",
  "version": "1.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/EugeneDraitsev/telegram-bot-app"
  },
  "author": "Eugene Draitsev <ddrrai@gmail.com>",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "sls offline start --stage local",
    "build": "bun run prepare:sharp-layer && sls package",
    "tsc": "tsgo --noEmit",
    "tsc:js": "tsc --noEmit",
    "test": "bun test",
    "biome": "biome check ./src",
    "biome:fix": "biome check ./src --fix --unsafe",
    "logs": "sls logs -f telegram-bot -t",
    "deploy": "bun run prepare:sharp-layer && sls deploy",
    "prepare:sharp-layer": "bun tools/prepare-sharp-layer.mts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/aws-lambda": "^8.10.162",
    "@types/jest": "^30.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260608.1",
    "esbuild": "0.28.0",
    "serverless": "^4.37.0",
    "serverless-esbuild": "^1.57.2",
    "serverless-offline": "^14.7.2",
    "typescript": "^6.0.3"
  },
  "workspaces": [
    "src/*"
  ],
  "overrides": {
    "@smithy/types": "^4.14.3"
  }
}
