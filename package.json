{
  "name": "chat-bot",
  "version": "1.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/EugeneDraitsev/telegram-bot-app"
  },
  "author": "Eugene Draitsev <ddrrai@gmail.com>",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "sls offline start --stage local",
    "build": "bun run prepare:sharp-layer && sls package",
    "tsc": "tsc --noEmit",
    "test": "bun test",
    "biome": "biome check ./src",
    "biome:fix": "biome check ./src --fix --unsafe",
    "logs": "sls logs -f telegram-bot -t",
    "deploy": "bun run prepare:sharp-layer && sls deploy",
    "prepare:sharp-layer": "node tools/prepare-sharp-layer.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "^30.0.0",
    "esbuild": "0.27.4",
    "serverless": "^4.36.0",
    "serverless-esbuild": "^1.57.1",
    "serverless-offline": "^14.6.0",
    "typescript": "^6.0.3"
  },
  "workspaces": [
    "src/*"
  ]
}
